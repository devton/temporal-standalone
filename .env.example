# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_PASSWORD=temporal_password_change_me

# ============================================
# MinIO (Object Storage para Archive)
# ============================================
MINIO_USER=temporal
MINIO_PASSWORD=temporal_archive_password_change_me

# ============================================
# Temporal UI Authentication
# ============================================
# Opção 1: Auth local simples (desenvolvimento)
AUTH_TYPE=local

# Opção 2: OAuth/OIDC (produção)
# AUTH_TYPE=oidc
# AUTH_PROVIDER_URL=https://your-auth-provider.com
# AUTH_CLIENT_ID=your-client-id
# AUTH_CLIENT_SECRET=your-client-secret
# AUTH_CALLBACK_URL=http://localhost:8080/auth/callback
# AUTH_SCOPES=openid email profile

# ============================================
# JWT Configuration (para autorização)
# ============================================
# AUTH_ISSUER=https://your-auth-provider.com
# AUTH_CLAIM_MAPPER_URL=

# ============================================
# Temporal Server
# ============================================
LOG_LEVEL=info
