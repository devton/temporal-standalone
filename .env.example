# Temporal Standalone Configuration
# Copy this file to .env and adjust values as needed

# ============================================
# Host Configuration
# ============================================
# Use "localhost" for local development
# Use your IP (e.g., "192.168.2.68") for network access
TEMPORAL_HOST=localhost

# ============================================
# Ports (usually don't need to change)
# ============================================
TEMPORAL_SERVER_PORT=7233
TEMPORAL_UI_PORT=8080
CASDOOR_PORT=8000
POSTGRES_PORT=5432

# ============================================
# OIDC Configuration (Casdoor)
# ============================================
# These should match your Casdoor application settings
OIDC_CLIENT_ID=8269b3a04ee85269e59c
OIDC_CLIENT_SECRET=1ef7a535169058cfa0f65960036a959b390f1447
