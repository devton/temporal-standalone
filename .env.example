# Temporal Standalone Configuration
# Copy this file to .env and adjust values as needed

# ============================================
# Network Configuration
# ============================================
# Use 'localhost' for local development
# Use your IP (e.g., '192.168.2.68') for network access from other machines
TEMPORAL_HOST=localhost

# ============================================
# Service Ports (optional, defaults shown)
# ============================================
# TEMPORAL_UI_PORT=8080
# TEMPORAL_SERVER_PORT=7233
# CASDOOR_PORT=8000
# POSTGRES_PORT=5432

# ============================================
# Casdoor OIDC Configuration
# ============================================
# Get these from your Casdoor application settings
CASDOOR_CLIENT_ID=your-client-id-here
CASDOOR_CLIENT_SECRET=your-client-secret-here

# ============================================
# JWT Configuration
# ============================================
# Secret for signing API key JWT tokens
# CHANGE THIS IN PRODUCTION! Use a strong random string.
JWT_SECRET=change-this-in-production-use-strong-random-string

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_USER=temporal
POSTGRES_PASSWORD=temporal
POSTGRES_DB=temporal
